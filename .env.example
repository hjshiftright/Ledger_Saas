# ─────────────────────────────────────────────────────────────────────────────
# Ledger 3.0 — Environment Variables
# Copy this file to .env and fill in the values before starting the application.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# App traffic → PgBouncer (connection pooler) → PostgreSQL
# PgBouncer multiplexes many app connections into a small fixed server-side pool.
# ssl=False is encoded via connect_args in engine.py (private Docker network).
DATABASE_URL=postgresql+asyncpg://ledger:ledger_secret@pgbouncer:6432/ledger

# Admin / migrations → PostgreSQL directly (bypasses PgBouncer)
# DDL statements and Alembic migrations require a stable session connection.
ADMIN_DATABASE_URL=postgresql+asyncpg://ledger:ledger_secret@db:5432/ledger

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
SECRET_KEY=change-me-before-going-to-production   # JWT signing secret — must be a long random string
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# ── LLM Providers (optional — required only for AI features) ─────────────────
# Google Gemini
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
# OPENAI_BASE_URL=          # Optional: Azure endpoint or local proxy

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_TEXT_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-20241022

# Which provider to use when no provider is specified per-request
DEFAULT_LLM_PROVIDER=GOOGLE   # GOOGLE | OPENAI | ANTHROPIC

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_BACKEND=local         # local | s3
STORAGE_BASE_PATH=./storage
MAX_UPLOAD_SIZE_MB=50

# ── Parser ────────────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.75
OCR_LANGUAGE=eng+hin
